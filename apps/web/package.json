{
  "name": "web",
  "version": "1.0.0",
  "description": "DND는 개발자와 디자이너라면 누구나 참여할 수 있는 IT비영리단체입니다.",
  "license": "GPL-3.0-only",
  "author": "dnd-academy",
  "scripts": {
    "open-browser": "open http://dnd-academy.localhost:3000",
    "dev": "next dev --webpack -H dnd-academy.localhost -p 3000 & yarn open-browser",
    "build": "yarn generate:applicant-count && next build --webpack",
    "start": "next start",
    "lint": "eslint '**/*.{js,jsx,ts,tsx}' --fix",
    "stylelint": "stylelint **/*.scss",
    "test:unit": "jest",
    "test:watch": "jest --watch",
    "test:watchAll": "jest --watchAll",
    "test:coverage": "yarn test:unit --coverage",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "check-types": "tsc --noEmit",
    "test:e2e": "start-server-and-test dev http://localhost:3000 cypress:run",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "build:scripts": "tsc --project tsconfig.scripts.json",
    "generate:applicant-count": "yarn build:scripts && node dist/scripts/generate-applicant-count.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DNDACADEMY/dnd-academy-v2.git"
  },
