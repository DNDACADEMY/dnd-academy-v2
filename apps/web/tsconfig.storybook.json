{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "bundler"
  },
  "include": [
    "@types/**/*.d.ts",
    "next-env.d.ts",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "../../packages/ui/src/**/*.d.ts",
    "../../packages/ui/src/**/*.stories.ts",
    "../../packages/ui/src/**/*.stories.tsx",
    "../../packages/ui/src/**/*.mdx"
  ],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "cypress", "storybook-static"]
}
