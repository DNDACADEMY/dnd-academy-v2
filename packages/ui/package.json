{
  "name": "@dnd-academy/ui",
  "version": "1.0.0",
  "description": "dnd-academy ui library",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./index.d.ts"
    },
    "./server": {
      "import": "./dist/server.mjs",
      "require": "./dist/server.js",
      "types": "./server.d.ts"
    },
    "./client": {
      "import": "./dist/client.mjs",
      "require": "./dist/client.js",
      "types": "./client.d.ts"
    },
    "./style.css": "./dist/style.css",
    "./styles": "./src/styles/index.scss",
    "./styles/*": "./src/styles/*"
  },
  "typesVersions": {
    "*": {
      "server": [
        "./server.d.ts"
      ],
      "client": [
        "./client.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "src/styles",
    "server.d.ts",
    "client.d.ts",
    "index.d.ts"
  ],
  "license": "GPL-3.0-only",
  "author": "dnd-academy",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "jest",
    "test:watch": "jest --watch",
    "test:watchAll": "jest --watchAll",
    "test:coverage": "yarn test:unit --coverage",
    "stylelint": "stylelint **/*.scss",
    "lint": "eslint \"**/*.ts*\""
  },
  "dependencies": {
    "@dnd-academy/core": "workspace:*",
    "clsx": "2.1.1",
    "motion": "11.14.4",
    "react-countup": "6.5.3",
    "sanitize.css": "13.0.0"
  },
  "devDependencies": {
    "@dnd-academy/eslint-config": "workspace:*",
    "@storybook/addon-docs": "10.4.1",
    "@storybook/react": "10.4.1",
    "@swc/core": "1.6.13",
    "@swc/jest": "0.2.36",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/identity-obj-proxy": "^3",
    "@types/jest": "30.0.0",
    "@types/jest-plugin-context": "2.9.7",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "8.59.4",
    "@vitejs/plugin-react": "5.2.0",
    "eslint": "10.4.0",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-storybook": "10.4.0",
    "eslint-plugin-testing-library": "7.16.2",
    "eslint-plugin-unused-imports": "4.4.1",
    "identity-obj-proxy": "3.0.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jest-plugin-context": "2.9.0",
    "next": "16.2.6",
    "postcss": "8.5.15",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "rollup": "4.60.4",
    "rollup-preserve-directives": "1.1.3",
    "sass": "1.69.6",
    "storybook": "10.4.1",
    "stylelint": "17.11.1",
    "stylelint-config-recommended-scss": "17.0.1",
    "stylelint-config-standard": "40.0.0",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-scss": "7.1.1",
    "typescript": "5.2.2",
    "vite": "6.4.2",
    "vite-plugin-dts": "5.0.1",
    "vite-plugin-svgr": "5.2.0"
  },
  "peerDependencies": {
    "clsx": "2.1.1",
    "motion": "11.14.4",
    "next": "^15 || ^16",
    "react": "^19",
    "react-countup": "6.5.3",
    "react-dom": "^19",
    "sass": "^1.69.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DNDACADEMY/dnd-academy-v2.git"
  },
  "bugs": {
    "email": "dbd02169@naver.com",
    "url": "https://github.com/DNDACADEMY/dnd-academy-v2/issues"
  }
}
