{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["GOOGLE_CLIENT_EMAIL", "GOOGLE_PRIVATE_KEY"],
  "tasks": {
    "deploy": {
      "env": ["GOOGLE_CLIENT_EMAIL", "GOOGLE_PRIVATE_KEY"],
      "dependsOn": ["lint", "stylelint", "test:coverage", "build"]
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "ADMIN_ORIGIN",
        "ALLOWED_EMAIL_ADDRESSES",
        "AUTH_GOOGLE_ID",
        "AUTH_GOOGLE_SECRET",
        "AUTH_SECRET",
        "BLOB_READ_WRITE_TOKEN",
        "CRON_SECRET",
        "DND_ACADEMY_V2_BLOB_READ_WRITE_TOKEN",
        "GOOGLE_CLIENT_EMAIL",
        "GOOGLE_PRIVATE_KEY",
        "NEXT_PUBLIC_CHANNEL_IO_PLUGIN_KEY",
        "NEXT_PUBLIC_GA_MEASUREMENT_ID",
        "NEXT_PUBLIC_ORIGIN",
        "NEXT_PUBLIC_THEME",
        "NEXT_PUBLIC_VERCEL_BLOB_HOST",
        "REVALIDATION_TOKEN",
        "WEB_ORIGIN"
      ],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.stories.{tsx,mdx}", "!**/*.test.{tsx,ts}"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["@dnd-academy/ui#build"],
      "inputs": ["**/*.{js,jsx,ts,tsx}"]
    },
    "stylelint": {
      "inputs": ["**/*.{scss,css}"]
    },
    "test:coverage": {
      "dependsOn": ["@dnd-academy/ui#build"],
      "outputs": ["coverage/**"],
      "inputs": ["**/*.test.{tsx,ts}"]
    },
    "dev": {
      "persistent": true,
      "cache": false,
      "interactive": true
    }
  }
}
